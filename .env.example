# RunWhen Platform MCP Server Configuration
#
# RunWhen API URL (required)
# For hosted: https://papi.<your-domain>.runwhen.com
# The Agent URL is derived automatically by swapping "papi" → "agentfarm"
RW_API_URL=https://papi.beta.runwhen.com

# RunWhen web app origin (optional). Used to build workspace_chat ``chatUrl`` (open session in UI).
# If unset, derived from RW_API_URL by swapping "papi" → "app" (e.g. https://app.beta.runwhen.com).
# Set explicitly when RW_API_URL is an internal URL (e.g. http://papi.backend-services.svc.cluster.local).
# RUNWHEN_APP_URL=https://app.beta.runwhen.com

# Your RunWhen API token (PAPI JWT)
#
# This SAME token is used for both PAPI and AgentFarm (mirrors how the frontend works).
# AgentFarm validates it by calling back to PAPI's agentfarm-params endpoint.
#
# Get a token via one of:
#   1. POST /api/v3/token/ with {"email": "...", "password": "..."}  (1-day lifetime)
#   2. Copy from browser: Dev Tools → Network → any API request → Authorization header
#   3. Create a Personal Access Token in RunWhen UI → Settings → Access Tokens (up to 180 days)
#
RUNWHEN_TOKEN=your-jwt-token-here

# Default workspace (optional — if set, tools won't require workspace_name)
DEFAULT_WORKSPACE=

# Workspace short name for live smoke tests / scripts (optional; default t-oncall)
# RW_SMOKE_WORKSPACE=t-oncall

# Deployed streamable HTTP MCP (pytest tests/test_mcp_http_remote_smoke.py & CI)
# Full URL to the /mcp endpoint — same as Cursor "url" (no trailing slash).
# RUNWHEN_MCP_URL=https://mcp.<env>.runwhen.com/mcp

# Override path to RUNWHEN.md (optional — by default, auto-discovered by walking
# up from the current working directory). Only set this if the file is outside
# the project tree.
# RUNWHEN_CONTEXT_FILE=/path/to/RUNWHEN.md

# Human-readable label for this server instance (optional).
# When multiple RunWhen MCP servers are configured for different environments,
# this label is included in the server name and instructions so LLM agents can
# distinguish which server targets which environment.
# If not set, the label is derived from RW_API_URL and DEFAULT_WORKSPACE.
# Examples: "prod", "beta", "staging", "watcher"
# MCP_SERVER_LABEL=beta

# CodeBundle Registry URL (optional — defaults to https://registry.runwhen.com).
# The registry is public; no authentication required.
# RUNWHEN_REGISTRY_URL=https://registry.runwhen.com

# ---------------------------------------------------------------------------
# Remote / HTTP mode (set MCP_TRANSPORT=http to enable)
# ---------------------------------------------------------------------------

# Transport mode: "stdio" (default, local) or "http" (remote/hosted)
# MCP_TRANSPORT=http

# HTTP server bind address and port (only used when MCP_TRANSPORT=http)
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# Enable stateless HTTP mode for horizontal scaling behind a load balancer
# FASTMCP_STATELESS_HTTP=true

# Auth0 OAuth configuration (optional — enables interactive OAuth 2.1 login)
# MCP_AUTH0_CONFIG_URL=https://your-auth0-domain/.well-known/openid-configuration
# MCP_AUTH0_CLIENT_ID=your-auth0-client-id
# MCP_AUTH0_CLIENT_SECRET=your-auth0-client-secret
# MCP_AUTH0_AUDIENCE=your-auth0-api-audience

# Public URL of this MCP server (required for OAuth flows)
# MCP_BASE_URL=https://mcp.beta.runwhen.com
