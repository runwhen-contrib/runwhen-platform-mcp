# RunWhen Platform MCP Server Configuration
#
# RunWhen API URL (required)
# For hosted: https://papi.<your-domain>.runwhen.com
# The Agent URL is derived automatically by swapping "papi" → "agentfarm"
RW_API_URL=https://papi.beta.runwhen.com

# Your RunWhen API token (PAPI JWT)
#
# This SAME token is used for both PAPI and AgentFarm (mirrors how the frontend works).
# AgentFarm validates it by calling back to PAPI's agentfarm-params endpoint.
#
# Get a token via one of:
#   1. POST /api/v3/token/ with {"email": "...", "password": "..."}  (1-day lifetime)
#   2. Copy from browser: Dev Tools → Network → any API request → Authorization header
#   3. Create a Personal Access Token in RunWhen UI → Settings → Access Tokens (up to 180 days)
#
RUNWHEN_TOKEN=your-jwt-token-here

# Default workspace (optional — if set, tools won't require workspace_name)
DEFAULT_WORKSPACE=

# Override path to RUNWHEN.md (optional — by default, auto-discovered by walking
# up from the current working directory). Only set this if the file is outside
# the project tree.
# RUNWHEN_CONTEXT_FILE=/path/to/RUNWHEN.md
